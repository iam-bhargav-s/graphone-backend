generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Paper {
  id              String            @id @default(uuid())
  slug            String            @unique
  title           String
  shortTitle      String?           @map("short_title")
  abstract        String?
  tlDr            String?           @map("tl_dr")
  publicationDate DateTime?         @map("publication_date")
  submissionDate  DateTime?         @map("submission_date")
  arxivId         String?           @unique @map("arxiv_id")
  doi             String?
  paperUrl        String?           @map("paper_url")
  pdfUrl          String?           @map("pdf_url")
  sourceUrl       String?           @map("source_url")
  projectUrl      String?           @map("project_url")
  citationCount   Int               @default(0) @map("citation_count")
  referenceCount  Int               @default(0) @map("reference_count")
  pageCount       Int?              @map("page_count")
  paperType       String?           @map("paper_type")
  status          String?
  language        String?
  license         String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime?         @updatedAt @map("updated_at")
  githubForks     Int?              @default(0) @map("github_forks")
  githubStars     Int?              @default(0) @map("github_stars")
  githubUrl       String?           @map("github_url")
  authors         PaperAuthor[]
  conferences     PaperConference[]
  datasets        PaperDataset[]
  journals        PaperJournal[]
  labs            PaperLab[]
  methods         PaperMethod[]
  models          PaperModel[]
  repositories    PaperRepository[]
  tasks           PaperTask[]
  universities    PaperUniversity[]
  rankings        Ranking[]
  sotaClaims      SotaClaim[]
  summaries       Summary[]

  @@map("papers")
}

model EntityRelationship {
  id               String @id @default(uuid())
  sourceEntityType String @map("source_entity_type")
  sourceEntityId   String @map("source_entity_id")
  targetEntityType String @map("target_entity_type")
  targetEntityId   String @map("target_entity_id")
  relationshipType String @map("relationship_type")
  weight           Float  @default(1.0)
  metadataJson     Json?  @map("metadata_json")

  @@unique([sourceEntityId, targetEntityId, relationshipType])
  @@index([sourceEntityType, sourceEntityId])
  @@index([targetEntityType, targetEntityId])
  @@map("entity_relationships")
}

model Startup {
  id            String   @id @default(uuid())
  canonicalName String   @unique @map("canonical_name")
  sourceName    String?  @map("source_name")
  sourceUrl     String?  @map("source_url")
  employeeCount Int?     @map("employee_count")
  collectedAt   DateTime @default(now()) @map("collected_at")

  @@map("startups")
}

model Task {
  id     String      @id @default(uuid())
  name   String      @unique
  slug   String      @unique
  color  String?
  papers PaperTask[]

  @@map("tasks")
}

model PaperTask {
  paper_id String
  task_id  String
  paper    Paper  @relation(fields: [paper_id], references: [id])
  task     Task   @relation(fields: [task_id], references: [id])

  @@id([paper_id, task_id])
  @@map("paper_tasks")
}

model Method {
  id     String        @id @default(uuid())
  name   String        @unique
  slug   String        @unique
  papers PaperMethod[]

  @@map("methods")
}

model PaperMethod {
  paper_id  String
  method_id String
  method    Method @relation(fields: [method_id], references: [id])
  paper     Paper  @relation(fields: [paper_id], references: [id])

  @@id([paper_id, method_id])
  @@map("paper_methods")
}

model Benchmark {
  id       String      @id @default(uuid())
  name     String      @unique
  slug     String      @unique
  rankings Ranking[]
  claims   SotaClaim[]

  @@map("benchmarks")
}

model SotaClaim {
  id           String    @id @default(uuid())
  paper_id     String
  benchmark_id String
  benchmark    Benchmark @relation(fields: [benchmark_id], references: [id])
  paper        Paper     @relation(fields: [paper_id], references: [id])

  @@unique([paper_id, benchmark_id])
  @@map("sota_claims")
}

model Ranking {
  id            String    @id @default(uuid())
  paper_id      String
  benchmark_id  String
  rank          Int
  previous_rank Int?
  updated_at    DateTime  @updatedAt
  benchmark     Benchmark @relation(fields: [benchmark_id], references: [id])
  paper         Paper     @relation(fields: [paper_id], references: [id])

  @@unique([paper_id, benchmark_id])
  @@index([benchmark_id, rank])
  @@map("rankings")
}

model Author {
  id        String        @id @default(uuid())
  name      String
  slug      String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  papers    PaperAuthor[]

  @@map("authors")
}

model PaperAuthor {
  paper_id  String
  author_id String
  author    Author @relation(fields: [author_id], references: [id], onDelete: Cascade)
  paper     Paper  @relation(fields: [paper_id], references: [id], onDelete: Cascade)

  @@id([paper_id, author_id])
  @@map("paper_authors")
}

model Model {
  id        String       @id @default(uuid())
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  papers    PaperModel[]

  @@map("models")
}

model PaperModel {
  paper_id String
  model_id String
  model    Model  @relation(fields: [model_id], references: [id], onDelete: Cascade)
  paper    Paper  @relation(fields: [paper_id], references: [id], onDelete: Cascade)

  @@id([paper_id, model_id])
  @@map("paper_models")
}

model Dataset {
  id        String         @id @default(uuid())
  name      String
  slug      String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  papers    PaperDataset[]

  @@map("datasets")
}

model PaperDataset {
  paper_id   String
  dataset_id String
  dataset    Dataset @relation(fields: [dataset_id], references: [id], onDelete: Cascade)
  paper      Paper   @relation(fields: [paper_id], references: [id], onDelete: Cascade)

  @@id([paper_id, dataset_id])
  @@map("paper_datasets")
}

model Lab {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  papers    PaperLab[]

  @@map("labs")
}

model PaperLab {
  paper_id String
  lab_id   String
  lab      Lab    @relation(fields: [lab_id], references: [id], onDelete: Cascade)
  paper    Paper  @relation(fields: [paper_id], references: [id], onDelete: Cascade)

  @@id([paper_id, lab_id])
  @@map("paper_labs")
}

model University {
  id        String            @id @default(uuid())
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  papers    PaperUniversity[]

  @@map("universities")
}

model PaperUniversity {
  paper_id      String
  university_id String
  paper         Paper      @relation(fields: [paper_id], references: [id], onDelete: Cascade)
  university    University @relation(fields: [university_id], references: [id], onDelete: Cascade)

  @@id([paper_id, university_id])
  @@map("paper_universities")
}

model Conference {
  id        String            @id @default(uuid())
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  papers    PaperConference[]

  @@map("conferences")
}

model PaperConference {
  paper_id      String
  conference_id String
  conference    Conference @relation(fields: [conference_id], references: [id], onDelete: Cascade)
  paper         Paper      @relation(fields: [paper_id], references: [id], onDelete: Cascade)

  @@id([paper_id, conference_id])
  @@map("paper_conferences")
}

model Journal {
  id        String         @id @default(uuid())
  name      String
  slug      String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  papers    PaperJournal[]

  @@map("journals")
}

model PaperJournal {
  paper_id   String
  journal_id String
  journal    Journal @relation(fields: [journal_id], references: [id], onDelete: Cascade)
  paper      Paper   @relation(fields: [paper_id], references: [id], onDelete: Cascade)

  @@id([paper_id, journal_id])
  @@map("paper_journals")
}

model Repository {
  id        String            @id @default(uuid())
  url       String            @unique
  name      String
  owner     String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  papers    PaperRepository[]

  @@map("repositories")
}

model PaperRepository {
  paper_id      String
  repository_id String
  paper         Paper      @relation(fields: [paper_id], references: [id], onDelete: Cascade)
  repository    Repository @relation(fields: [repository_id], references: [id], onDelete: Cascade)

  @@id([paper_id, repository_id])
  @@map("paper_repositories")
}

model User {
  id        String   @id @default(uuid())

  username  String   @unique
  email     String   @unique
  password  String

  displayName String

  avatar    String?
  bio       String?

  github    String?
  twitter   String?
  website   String?

  reputationScore Int @default(0)

  auth_id   String? @unique

  summaries Summary[]
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model RefreshToken {
  id String @id @default(uuid())

  token String @unique

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime

  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Summary {
  id        String   @id @default(uuid())
  content   String
  paper_id  String
  user_id   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  paper     Paper    @relation(fields: [paper_id], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("summaries")
}
